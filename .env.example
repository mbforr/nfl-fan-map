# Local dev: copy this file to .env and fill in real values.
# Vercel deploy: set these as Environment Variables in the project settings
# (do NOT commit .env). VITE_* values get inlined into the client bundle at
# build time, so for the Mapbox token, restrict it to your deployed domain
# under Mapbox account → Tokens → URL restrictions.

VITE_MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN_HERE
VITE_SURVEY_URL=https://docs.google.com/forms/your-survey-here
